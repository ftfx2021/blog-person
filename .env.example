# 环境变量示例文件
# 复制此文件为 .env 并填入实际值

# 应用环境配置
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/personal_blog?useUnicode=true&characterEncoding=utf-8&allowMultiQueries=true&useSSL=false&serverTimezone=GMT%2b8&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# 邮件配置
MAIL_HOST=smtp.qq.com
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_password
MAIL_PORT=587

# 用户默认密码
DEFAULT_PASSWORD=123456

# 文件上传配置
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# Knife4j配置
KNIFE4J_ENABLE=false
KNIFE4J_USERNAME=admin
KNIFE4J_PASSWORD=admin

# Spring Security配置
SECURITY_USERNAME=admin
SECURITY_PASSWORD=admin

# Swagger配置
SWAGGER_ENABLED=false

# 应用URL配置
API_BASE_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com
ADMIN_URL=https://admin.yourdomain.com
UPLOAD_PATH=/var/www/files/
FILE_URL_PREFIX=https://files.yourdomain.com/
